{
  "version": 2,
  "routes": [
    { "src": "/api/dca", "dest": "/api/dca" },
    { "src": "/api/notify", "dest": "/api/notify" },
    { "src": "/api/claude", "dest": "/api/claude" },
    { "src": "/api/close", "dest": "/api/close" },
    { "src": "/api/autotrade", "dest": "/api/autotrade" },
    { "src": "/api/db", "dest": "/api/db" },
    { "src": "/api/prices", "dest": "/api/prices" },
    { "src": "/api/review", "dest": "/api/review" },
    { "src": "/api/signal", "dest": "/api/signal" },
    { "src": "/api/indicators", "dest": "/api/indicators" },
    { "src": "/api/calendar", "dest": "/api/calendar" },
    { "src": "/ig/(.+)", "dest": "/api/ig?path=$1" },
    { "src": "/lightstreamer.min.js", "dest": "/lightstreamer.min.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
