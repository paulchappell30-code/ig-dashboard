{
  "version": 2,
  "rewrites": [
    { "source": "/ig/:path*", "destination": "/api/ig?path=:path*" },
    { "source": "/api/dca", "destination": "/api/dca" },
    { "source": "/api/notify", "destination": "/api/notify" },
    { "source": "/api/rules", "destination": "/api/rules" },
    { "source": "/api/claude", "destination": "/api/claude" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
